{
  "name": "guided-discovery-pi-package",
  "version": "0.4.0",
  "description": "pi review workflow extension that compares a change with two alternate top-level models, deduplicates the findings, and lets you choose which ones to address.",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "agents",
    "agents-checks.ts",
    "changes.ts",
    "guidance.ts",
    "implement-workflow.ts",
    "implementation-progress.ts",
    "implementation-progress-widget.ts",
    "implementation-prompt.ts",
    "index.ts",
    "models.ts",
    "questionnaire-model.ts",
    "questionnaire.ts",
    "repo.ts",
    "review-workflow.ts",
    "structured-output.ts",
    "subagent-runner.ts",
    "tui-compat.ts",
    "usage-display.ts",
    "utils.ts",
    "widget-support.ts",
    "workspaces.ts",
    "web-research.ts",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "scripts": {
    "build": "echo 'No build step required'",
    "check": "node --test ./tests/*.test.ts",
    "test": "node --test ./tests/*.test.ts"
  }
}
